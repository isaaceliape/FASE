# FASE Configuration Template
# 
# Copy this file to .env and customize values for your environment
# Optional variables can be left unset to use defaults
#
# Generated: April 21, 2026
# FASE Version: 4.0.2+


# ═══════════════════════════════════════════════════════════════════════════
# RUNTIME CONFIGURATION DIRECTORIES
# ═══════════════════════════════════════════════════════════════════════════
# 
# These variables allow you to customize where FASE looks for and stores
# configuration for different AI runtimes. If not set, defaults are used:
# - Claude Code: ~/.claude
# - OpenCode: ~/.config/opencode
# - Gemini: ~/.gemini
# - Codex: ~/.codex
# - GitHub Copilot: ~/.github-copilot
# - Qwen Code: ~/.qwen

# Optional: Custom Claude Code configuration directory
# Default: ~/.claude
# CLAUDE_CONFIG_DIR=~/.claude

# Optional: Custom OpenCode configuration directory
# Follows XDG Base Directory spec
# Default: ~/.config/opencode or $XDG_CONFIG_HOME/opencode
# OPENCODE_CONFIG_DIR=~/.config/opencode

# Optional: Custom OpenCode configuration file path
# Default: Derived from OPENCODE_CONFIG_DIR
# OPENCODE_CONFIG=~/.config/opencode/opencode.json

# Optional: Custom Gemini CLI configuration directory
# Default: ~/.gemini
# GEMINI_CONFIG_DIR=~/.gemini

# Optional: Custom Codex configuration directory
# Default: ~/.codex
# CODEX_HOME=~/.codex

# Optional: Custom GitHub Copilot configuration directory
# Default: ~/.github-copilot
# GITHUB_COPILOT_CONFIG_DIR=~/.github-copilot

# Optional: Custom Qwen Code configuration directory
# Default: ~/.qwen
# QWEN_CONFIG_DIR=~/.qwen


# ═══════════════════════════════════════════════════════════════════════════
# FASE INSTALLATION & RUNTIME
# ═══════════════════════════════════════════════════════════════════════════

# Optional: Override FASE home directory for testing
# Default: Automatically detected from package.json location
# FASE_HOME=/path/to/fase

# Optional: Specify which runtime FASE is running in
# Useful for debugging or testing specific provider behavior
# Supported values: claude, opencode, gemini, codex, github-copilot, qwen
# FASE_RUNTIME=claude


# ═══════════════════════════════════════════════════════════════════════════
# DEVELOPMENT & TESTING
# ═══════════════════════════════════════════════════════════════════════════

# Internal: Test mode flag (do not set manually)
# Set by test suite to skip main execution when module is loaded
# FASE_TEST_MODE=1


# ═══════════════════════════════════════════════════════════════════════════
# EXTERNAL INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════

# Optional: Brave search API key for search integration
# Get your API key at: https://api.search.brave.com/
# BRAVE_API_KEY=your_brave_api_key_here


# ═══════════════════════════════════════════════════════════════════════════
# SYSTEM ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════

# Optional: XDG Base Directory specification
# Used by OpenCode and other XDG-compliant applications
# Default: ~/.config
# XDG_CONFIG_HOME=~/.config


# ═══════════════════════════════════════════════════════════════════════════
# INSTALLATION NOTES
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. Path Expansion:
#    - Tilde (~) is automatically expanded to your home directory
#    - Relative paths are resolved from current working directory
#    - Absolute paths are used as-is
#
# 2. Priority Order (for each runtime):
#    FASE CLI argument (--config-dir) > Environment variable > Default location
#
#    Examples:
#    npx fase-ai --claude --config-dir ~/.my-claude-config
#    CLAUDE_CONFIG_DIR=~/.my-claude-config npx fase-ai --claude
#
# 3. Multiple Runtimes:
#    You can customize configuration for multiple runtimes simultaneously
#    Each runtime uses its own configuration directory
#
# 4. OpenCode Special Case:
#    OpenCode follows XDG Base Directory spec and supports:
#    - OPENCODE_CONFIG_DIR: explicit directory
#    - OPENCODE_CONFIG: explicit config file
#    - XDG_CONFIG_HOME: XDG base directory
#    - Default: ~/.config/opencode
#
# 5. Testing & Development:
#    Set FASE_TEST_MODE=1 when running tests to prevent main execution
#    This is handled automatically by the test suite
#
# ═══════════════════════════════════════════════════════════════════════════
#
# USAGE EXAMPLES
# ═══════════════════════════════════════════════════════════════════════════
#
# Example 1: Custom Claude Code directory
# ─────────────────────────────────────────
#   CLAUDE_CONFIG_DIR=~/.claude-custom npx fase-ai --claude
#
# Example 2: Multiple custom directories
# ────────────────────────────────────────
#   CLAUDE_CONFIG_DIR=~/.claude-custom \
#   GEMINI_CONFIG_DIR=~/.gemini-custom \
#   npx fase-ai --all
#
# Example 3: With search integration
# ────────────────────────────────────
#   BRAVE_API_KEY=xxxx npx fase-ai --claude
#
# Example 4: Development/Testing
# ───────────────────────────────
#   FASE_TEST_MODE=1 npm test
#
# ═══════════════════════════════════════════════════════════════════════════
